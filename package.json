{
	"name": "poker",
	"version": "0.1.0",
	"private": true,
	"scripts": {
		"dev": "next dev",
		"build": "next build",
		"start": "next start",
		"test": "bun test src/game/__tests__/PokerGame.test.ts",
		"test:unit": "bun test src/game/__tests__/PokerGame.test.ts",
		"test:e2e": "playwright test",
		"test:e2e:headed": "playwright test --headed",
		"lint": "biome check .",
		"format": "biome format --write .",
		"prepare": "husky"
	},
	"lint-staged": {
		"*.{js,ts,cjs,mjs,d.cts,d.mts,jsx,tsx,json,jsonc,css}": [
			"biome check --write --no-errors-on-unmatched"
		]
	},
	"dependencies": {
		"@pokertools/engine": "^1.0.1",
		"next": "16.1.6",
		"process": "^0.11.10",
		"react": "19.2.4",
		"react-dom": "19.2.4",
		"seedrandom": "^3.0.5"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.6",
		"@playwright/test": "^1.58.2",
		"@types/node": "^25.3.3",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@types/seedrandom": "^3.0.8",
		"husky": "^9.1.7",
		"lint-staged": "^16.3.2",
		"typescript": "^5.9.3"
	},
	"ignoreScripts": [
		"sharp",
		"unrs-resolver"
	],
	"trustedDependencies": [
		"sharp",
		"unrs-resolver"
	]
}
